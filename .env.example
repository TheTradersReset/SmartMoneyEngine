# FYERS API credentials (never commit real values)
FYERS_APP_ID=your_app_id-100
# Optional alias if FYERS_APP_ID is unset:
# FYERS_CLIENT_ID=your_app_id-100
FYERS_SECRET_KEY=your_secret_key
FYERS_REDIRECT_URI=http://127.0.0.1:8000
FYERS_ACCESS_TOKEN=
FYERS_PIN=

# --- Live paper trading ---
# Primary alerts: SMTP email (Telegram blocked on many corporate networks)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
LIVE_PAPER_ENABLE_EMAIL=true

# Optional legacy Telegram (default off)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LIVE_PAPER_ENABLE_TELEGRAM=false

LIVE_PAPER_DB_PATH=data/paper/realtime_signals.db
LIVE_PAPER_HISTORY_CSV=outputs/pipeline/NIFTY50_5m_pipeline.csv
LIVE_PAPER_DASHBOARD_HOST=0.0.0.0
LIVE_PAPER_DASHBOARD_PORT=8080
LIVE_PAPER_STALE_TICK_SECONDS=30
LIVE_PAPER_HEARTBEAT_SECONDS=10
LIVE_PAPER_SYMBOL=NSE:NIFTY50-INDEX
LIVE_PAPER_ENABLE_DASHBOARD=true
LIVE_PAPER_CAPITAL_MODE=paper
# Phase-1 foundations (unused until later phases; keep false)
LIVE_PAPER_ENABLE_PIPELINE_V2=false
LIVE_PAPER_LIVE_CLOSE_QUEUE_MAX=32
LIVE_PAPER_SHUTDOWN_DRAIN_SEC=5.0
